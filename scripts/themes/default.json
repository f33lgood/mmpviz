{
  "schema_version": 1,
  "base": {
    "background": "#ffffff",
    "fill": "#e8e8e8",
    "break_fill": "#ffffff",
    "stroke": "#555555",
    "stroke_width": 1,
    "font_size": 13,
    "font_family": "Helvetica",
    "text_fill": "#000000",
    "text_stroke": "none",
    "text_stroke_width": 0,
    "opacity": 1,
    "break_height": 20,
    "min_section_height": 20,
    "max_section_height": 300
  },
  "links": {
    "connector": {
      "source":      { "width": 25 },
      "destination": { "width": 25 },
      "middle":      { "width": 10, "shape": "curve" },
      "fill":        "#e8e8e8",
      "opacity":     0.7
    }
  },
  "growth_arrow": {
    "size":   1,
    "fill":   "#e8e8e8",
    "stroke": "#555555"
  },
  "labels": {
    "arrow_size":       2,
    "stroke":           "#555555",
    "stroke_width":     1,
    "stroke_dasharray": "4,2"
  }
}
