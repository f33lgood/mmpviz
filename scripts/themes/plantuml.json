{
  "schema_version": 1,
  "extends": "default",
  "base": {
    "background": "#ffffff",
    "fill": "#FEFECE",
    "break_fill": "#ffffff",
    "stroke": "#A80036",
    "stroke_width": 1,
    "font_size": 12,
    "font_family": "Arial",
    "text_fill": "#000000",
    "text_stroke": "none",
    "text_stroke_width": 0,
    "opacity": 1,
    "break_height": 20,
    "min_section_height": 20,
    "max_section_height": 300
  },
  "growth_arrow": {
    "fill":   "#FEFECE",
    "stroke": "#A80036"
  },
  "links": {
    "connector": {
      "fill":    "#D8D8D8",
      "opacity": 0.6
    }
  },
  "labels": {
    "stroke": "#A80036",
    "stroke_width": 1,
    "stroke_dasharray": "4,2"
  }
}
