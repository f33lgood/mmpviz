{
  "_comment": [
    "Embedded-theme example: the diagram carries an inline theme object that",
    "'extends' a built-in and adds per-section overrides. No sidecar",
    "theme.json needed; this is the inline equivalent of extending a built-in",
    "from a sibling theme.json file.",
    "",
    "When the embedded form is used, 'extends' may only reference a built-in",
    "name ('default' or 'plantuml') — embedded themes have no on-disk anchor",
    "for relative-path inheritance."
  ],
  "title": "Embedded Theme — Extends Built-in with Section Overrides",
  "theme": {
    "extends": "default",
    "views": {
      "soc": {
        "sections": {
          "flash":    { "fill": "#aed6f1" },
          "sram":     { "fill": "#a9dfbf" },
          "periph":   { "fill": "#fdebd0" },
          "reserved": { "fill": "#d5d8dc" }
        }
      }
    }
  },
  "views": [
    {
      "id": "soc",
      "title": "SoC Memory Map",
      "sections": [
        { "id": "flash",    "address": "0x00000000", "size": "0x00100000", "name": "Flash (1 MiB)" },
        { "id": "gap1",     "address": "0x00100000", "size": "0x1FF00000", "name": "···", "flags": ["break"] },
        { "id": "sram",     "address": "0x20000000", "size": "0x00040000", "name": "SRAM (256 KiB)" },
        { "id": "gap2",     "address": "0x20040000", "size": "0x1FFC0000", "name": "···", "flags": ["break"] },
        { "id": "periph",   "address": "0x40000000", "size": "0x10000000", "name": "Peripherals" },
        { "id": "reserved", "address": "0x50000000", "size": "0xB0000000", "name": "Reserved" }
      ]
    }
  ]
}
