      }
    },
    "sram-view": {
      "background": "white",
      "fill": "#d8f3dc",
      "stroke": "#95d5b2",
      "text_fill": "#1b4332",
      "sections": {
        "bss":   { "fill": "#b7e4c7" },
        "heap":  { "fill": "#74c69d" },
        "stack": { "fill": "#52b788" }
      }
