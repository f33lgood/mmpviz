    "stroke": "#adb5bd",
    "stroke_width": 1,
    "font_size": 13,
    "font_family": "Helvetica",
    "text_fill": "#212529",
    "text_stroke": "none",
    "text_stroke_width": 0,
    "opacity": 1,
    "break_type": "≈",
    "break_size": 24,
    "growth_arrow_size": 1,
    "growth_arrow_fill": "#6c757d",
    "growth_arrow_stroke": "#495057",
    "hide_size": "auto",
